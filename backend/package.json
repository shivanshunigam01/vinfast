{
  "name": "patliputra-vinfast-backend",
  "version": "1.0.0",
  "description": "Node.js + Express + MongoDB backend for Patliputra Auto x VinFast dealer website and admin panel.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:td": "node scripts/seedTD.js",
    "seed:td:force": "node scripts/seedTD.js --force",
    "seed:td:module": "node scripts/seedTDModule.js",
    "seed:td:fleet": "node scripts/seedTDModule.js --force-fleet"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.2",
    "morgan": "^1.10.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
